# Telegram BotFather token
BOT_TOKEN=123456789:replace_with_your_telegram_bot_token

# OpenAI API key
OPENAI_API_KEY=sk-replace_with_your_openai_api_key

# Homework model. You can replace it if the exact dated model is unavailable in your account.
OPENAI_MODEL=gpt-5-mini-2025-08-07

# OpenAI Responses API uses max_output_tokens.
DEFAULT_MAX_OUTPUT_TOKENS=1200
OPENAI_TIMEOUT_SECONDS=45

# In-memory context limits
CONTEXT_MAX_MESSAGES=12
MAX_USER_MESSAGE_CHARS=3000
MAX_ASSISTANT_CONTEXT_CHARS=1800
TELEGRAM_CHUNK_SIZE=3800

# Cost estimate. Update before final report from current OpenAI pricing.
INPUT_PRICE_PER_1M_TOKENS_USD=0.25
OUTPUT_PRICE_PER_1M_TOKENS_USD=2.00

# If a GPT/reasoning model rejects optional parameters, the bot retries without them and logs a warning.
RETRY_WITHOUT_TEMPERATURE=true
RETRY_WITHOUT_REASONING=true

# Logging
LOG_DIR=logs
LOG_LEVEL=INFO
HASH_USER_IDS_IN_LOGS=true
LOG_SALT=change-me-before-demo
